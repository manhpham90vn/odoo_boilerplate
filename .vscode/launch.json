    "version": "0.2.0",
    "configurations": [
        {
            "name": "Odoo 17 Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/odoo-bin",
            "python": "${workspaceFolder}/venv/bin/python",
            "args": [
                "--dev=app",
                "--config",
                "${workspaceFolder}/etc/odoo.conf",
            ]
        }
    ]
}